                <mxCell id="19" value="一般表示&lt;strong data-end=&quot;259&quot; data-start=&quot;247&quot;&gt;机器人车体坐标系&lt;/strong&gt;，是固定在机器人本体上的 frame" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
                    <mxGeometry x="23" y="588.5" width="170" height="42.5" as="geometry"/>
                </mxCell>
                <mxCell id="21" value="&lt;strong data-start=&quot;823&quot; data-end=&quot;835&quot;&gt;局部里程计坐标系&lt;/strong&gt;，它通常在机器人启动或定位初始化时建立。它不是车上的某个点，而是一个“局部世界参考系”。来自轮速计、视觉里程计、IMU 。&lt;div&gt;会随&lt;b&gt;时间漂移，但短期准确且连续&lt;/b&gt;&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
                    <mxGeometry x="23" y="464.75" width="170" height="106.25" as="geometry"/>
                </mxCell>
                <mxCell id="22" value="" style="endArrow=classic;html=1;shape=flexArrow;" edge="1" parent="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="370" y="510" as="sourcePoint"/>
                        <mxPoint x="200" y="509.71" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="23" value="" style="endArrow=classic;html=1;shape=flexArrow;" edge="1" parent="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="370" y="608.75" as="sourcePoint"/>
                        <mxPoint x="200" y="608.46" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="26" value="每个模块只需要声明自己的数据在哪个 frame 下，系统通过 TF 树自动换算到目标 frame。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
                    <mxGeometry x="23" y="191" width="180" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="27" value="" style="endArrow=classic;html=1;shape=flexArrow;" edge="1" parent="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="370" y="410" as="sourcePoint"/>
                        <mxPoint x="200" y="409.71000000000004" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="28" value="来自全局定位、SLAM、AMCL、GNSS/INS 修正等，作用是&lt;strong data-end=&quot;2576&quot; data-start=&quot;2559&quot;&gt;修正 odom 的累计漂移。&lt;/strong&gt;&lt;div&gt;&lt;strong data-end=&quot;2576&quot; data-start=&quot;2559&quot;&gt;长期全局参考，&lt;/strong&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;可以发生离散跳变，&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;根据传感器观测不断重新计算机器人在地图中的位置&lt;/span&gt;&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
                    <mxGeometry x="23" y="354.75" width="170" height="106.25" as="geometry"/>
                </mxCell>
                <mxCell id="29" value="定位模块通常&lt;strong data-start=&quot;3265&quot; data-end=&quot;3271&quot;&gt;计算&lt;/strong&gt;&lt;div&gt;&lt;strong data-start=&quot;3265&quot; data-end=&quot;3271&quot;&gt;map -&amp;gt; base_link，&lt;/strong&gt;&lt;/div&gt;&lt;div&gt;&lt;strong data-start=&quot;3265&quot; data-end=&quot;3271&quot;&gt;但不广播，结合&lt;/strong&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;odom -&amp;gt; base_link，得到map -&lt;/b&gt;&lt;/span&gt;&lt;strong style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot; data-start=&quot;3265&quot; data-end=&quot;3271&quot;&gt;&amp;gt;&lt;/strong&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;&amp;nbsp;odom&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="520" y="370" width="120" height="98.12" as="geometry"/>
                </mxCell>
                <mxCell id="30" value="地心地固坐标系。&lt;span&gt;全球坐标到局部地图坐标。&lt;/span&gt;&lt;div&gt;多个机器人、多个地图、跨区域地图，初始化时没有可以后期接入。&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
